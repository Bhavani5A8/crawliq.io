# Netlify / Cloudflare Pages cache-control rules
# GitHub Pages ignores this file — to activate: deploy to Netlify or proxy via Cloudflare
# with a Cache Rule: "Cache Everything" + Edge TTL 1 year for static/*, *.css, *.js, *.png

# HTML pages — short cache, always revalidated (content changes)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Versioned static assets — immutable (cache forever, version string handles busting)
/static/css/*
  Cache-Control: public, max-age=31536000, immutable

/static/js/*
  Cache-Control: public, max-age=31536000, immutable

/static/img/*
  Cache-Control: public, max-age=31536000, immutable

# Sitemap and robots — revalidate daily
/sitemap.xml
  Cache-Control: public, max-age=86400, must-revalidate

/robots.txt
  Cache-Control: public, max-age=86400, must-revalidate
