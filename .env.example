# ──────────────────────────────────────────────────────────────────────────────
# CrawlIQ — Environment Variables Reference
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI Providers (at least one required) ─────────────────────────────────────
# Default provider — free tier at console.groq.com
AI_PROVIDER=groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-70b-8192

# Google Gemini (set AI_PROVIDER=gemini)
GEMINI_API_KEY=AIza...

# OpenAI (set AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Anthropic Claude (set AI_PROVIDER=claude)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing secret — change this to a long random string in production!
JWT_SECRET=change-me-to-something-random-in-production
# Token lifetime in days (default 30)
JWT_EXPIRE_DAYS=30

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe product catalog
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# ── Email Alerts (SMTP) ───────────────────────────────────────────────────────
# Leave blank to disable email (alerts logged instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
ALERT_FROM=CrawlIQ <your@gmail.com>
# Set to "1" to use SSL (port 465), leave "0" for STARTTLS (port 587)
SMTP_USE_TLS=0

# ── App Base URL ──────────────────────────────────────────────────────────────
# Used in email links and Stripe redirect URLs
APP_BASE_URL=http://localhost:7860

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use "*" only for local dev.
# Production example: ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=*

# ── Google Search Console OAuth (optional) ────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
# GSC_CLIENT_ID=...apps.googleusercontent.com
# GSC_CLIENT_SECRET=GOCSPX-...
# GSC_REDIRECT_URI=https://yourdomain.com/gsc/callback

# ── Server ────────────────────────────────────────────────────────────────────
# Port (default 7860 for HuggingFace Spaces)
PORT=7860
